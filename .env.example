# ============================================================================
# INTER CONNECT - 環境変数テンプレート
# ============================================================================
# 本ファイルは Git で共有される雛形。実値は `.env.local` に記入してください
# (`.gitignore` で除外済)。本番値は Netlify env / Supabase Secrets に設定。

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サービスロールキー (server-only / 絶対に NEXT_PUBLIC_ を付けない)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CSRF / Origin allowlist (api-helpers.ts) ─────────────────────────────
# カンマ区切り。未設定時は inter-connect.app, www.inter-connect.app を許可
ALLOWED_ORIGIN_HOSTS=inter-connect.app,www.inter-connect.app
# Netlify preview deploy (*.netlify.app) を許可するか
ALLOW_NETLIFY_PREVIEW=false

# ── External APIs ─────────────────────────────────────────────────────────
TLDV_API_KEY=your-tldv-api-key
TLDV_WEBHOOK_SECRET=your-tldv-webhook-shared-secret
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI text-embedding-3-small (worker/src/handlers/embed.ts)
OPENAI_API_KEY=sk-...

# ── Google Calendar OAuth (Phase B) ───────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
# OAuth state HMAC + token AES-GCM 用 (32 byte base64 推奨)
OAUTH_STATE_SECRET=replace-with-32-byte-random
CALENDAR_TOKEN_ENC_KEY=replace-with-32-byte-random

# ── tl;dv 同期 / 内部判定 ────────────────────────────────────────────────
# 内部ユーザーと判定するメールドメイン (カンマ区切り)
INTERCONNECT_INTERNAL_DOMAINS=inter-connect.app,ikemen.ltd
# 内部運用者の email (カンマ区切り)
INTERCONNECT_OPERATOR_EMAILS=interconnectltd3568@gmail.com
# 旧名 (互換用、新規は INTERCONNECT_* を使用)
TLDV_INTERNAL_DOMAINS=inter-connect.app,ikemen.ltd
TLDV_OPERATOR_EMAILS=interconnectltd3568@gmail.com
# tl;dv 1 同期あたりの最大件数
TLDV_MAX_MEETINGS=20
# 内部判定追加パターン (regex、optional)
TLDV_EXTRA_INTERNAL_PATTERNS=

# ── Worker / Cron 制限 ────────────────────────────────────────────────────
# 1 cron 実行あたりの解析ジョブ最大数
ANALYZE_MAX_JOBS=10
# 日次 Anthropic コスト上限 (USD、超過時 cron 停止)
ANALYZE_DAILY_USD_CAP=20
# 同様に集約ジョブ最大数
AGGREGATE_MAX_JOBS=20
